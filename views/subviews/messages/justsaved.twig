{# Message « réponse sauvegardée » — composant Alerte DSFR (fermable).
   savedClass correspond directement aux variantes DSFR : success / error / info.
   Le bouton de fermeture suit le pattern officiel DSFR (retrait du nœud).
   showpopups : >0 = popup core (alerte masquée via ls-js-hidden), 0 = sur la page. #}
{% if (intval(aSurveyInfo.options.showpopups) >= 0 and aSurveyInfo.saved.text) %}
    {% set savedClass = 'success' %}
    {% if (not aSurveyInfo.saved.success) %}
        {% set savedClass = 'error' %}
    {% endif %}
    {% if (aSurveyInfo.active != "Y") %}
        {% set savedClass = 'info' %}
    {% endif %}
    <div class="fr-alert fr-alert--{{ savedClass }} fr-alert--sm fr-mb-3w{% if(intval(aSurveyInfo.options.showpopups) > 0) %} ls-js-hidden{% endif %}">
        <p>{{ aSurveyInfo.saved.text }}</p>
        <button class="fr-btn--close fr-btn ls-no-js-hidden" title="{{ gT("Close") }}" onclick="const alertEl = this.parentNode; alertEl.parentNode.removeChild(alertEl)">{{ gT("Close") }}</button>
    </div>
{% endif %}
