{#
    (ยฏ`ยท._.ยท(ยฏ`ยท._.ยท  Assessments ยท._.ยทยดยฏ)ยท._.ยทยดยฏ)

    Rรฉsultats d'รฉvaluation โ€” composant Mise en avant (fr-callout) DSFR,
    en remplacement des tables Bootstrap imbriquรฉes.
    Les donnรฉes sont dans aSurveyInfo.aAssessments.datas
#}

{% set aAssessments = aSurveyInfo.aAssessments.datas %}
<!-- Assessments -->
<div class="{{ aSurveyInfo.class.assessmenttable }} lsd-assessments fr-mb-4w" {{ aSurveyInfo.attr.assessmenttable }}>

    <h2 class="fr-h4 {{ aSurveyInfo.class.assessmentheading }}" {{ aSurveyInfo.attr.assessmentheading }}>
        {{ gT("Your assessment") }}
    </h2>

    <div class="{{ aSurveyInfo.class.assessmentscontainer }}" {{ aSurveyInfo.attr.assessmentscontainer }}>
        {% if aAssessments.subtotal.show %}
        <!-- "Group" assessments -->
            {% for key,val in aAssessments.subtotal.datas %}
                {% if aAssessments.group %}
                    {% if key in aAssessments.group | keys %}
                        {% for assessed in aAssessments.group[key] %}
                            {% if ( val >= assessed.min and val <= assessed.max ) %}
                            {% set assesmentReplacement = { PERC: val, TOTAL: aAssessments.total_score, ASSESSMENT_CURRENT_TOTAL: aAssessments.total_score } %}
                            <div class="fr-callout fr-mb-2w">
                                <h3 class="fr-callout__title fr-text--md">
                                    {{ processString(assessed.name,true,3,assesmentReplacement) }}
                                </h3>
                                <p class="fr-callout__text fr-text--sm">
                                    {{ processString(assessed.message,true,3,assesmentReplacement) }}
                                </p>
                            </div>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                {% endif %}

            {% endfor %}
        {% endif %}

        {% set val = aAssessments.subtotal.datas | last  %}

        {% if aAssessments.total.show %}
            <!-- "Total" assessments -->
            {% for assessed in aAssessments.total %}
                {% if ( assessed is iterable and  aAssessments.total_score  >= assessed.min and aAssessments.total_score <= assessed.max ) %}
                {# val ({PERC}): It displays the score of a question group, it don't exist for global โ€ฆ take the last one (must remove it for 4.X: show an error) #}
                {% set assesmentReplacement = { PERC: val, TOTAL: aAssessments.total_score, ASSESSMENT_CURRENT_TOTAL: aAssessments.total_score } %}
                    <div class="fr-callout fr-callout--blue-cumulus fr-mb-2w">
                        <h3 class="fr-callout__title fr-text--md">
                            {{ processString(assessed.name,true,3,assesmentReplacement) }}
                        </h3>
                        <p class="fr-callout__text fr-text--sm">
                            {{ processString(assessed.message,true,3,assesmentReplacement) }}
                        </p>
                    </div>
                {% endif %}
            {% endfor %}
        {% endif %}

    </div>
</div>
