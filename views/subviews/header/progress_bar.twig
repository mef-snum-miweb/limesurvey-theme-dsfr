{#
    LimeSurvey - DSFR Theme
    Stepper DSFR officiel.

    Structure conforme : https://www.systeme-de-design.gouv.fr/composants-et-modeles/composants/indicateur-d-etapes/
    Traductions : utilise le dictionnaire {{ t }} défini dans layout_global.twig

    Données :
      - aSurveyInfo.progress.{currentstep,total,value} sont peuplés par
        SurveyRuntimeHelper::run() dès que showprogress=Y et format != 'A',
        indépendamment du paramètre "questionindex". Source de vérité du
        compteur d'étapes.
      - aSurveyInfo.aQuestionIndex.items n'existe que lorsque l'index des
        questions est activé (incremental ou full). Quand dispo, on enrichit
        l'affichage avec le libellé d'étape courante et le titre de l'étape
        suivante.
#}

{# Welcome page : `step` (variable globale passée par SurveyRuntimeHelper)
   vaut 0. Sur cet écran, le compteur d'étapes côté LS n'est pas encore
   calculé (totalsteps=1, currentstep=1) — afficher le stepper renverrait
   une barre pleine trompeuse. On masque jusqu'à la 1re vraie étape. #}
{% if aSurveyInfo.showprogress == 'Y' and aSurveyInfo.format != 'A' and not aSurveyInfo.aCompleted and step is defined and step > 0 %}
    {# Stepper sans margin-bottom : on porte l'espacement bas sur
       #outerframeContainer (cf. css/custom.css) pour que la marge reste
       cohérente même quand le stepper n'est pas rendu (questionnaire
       mono-page, format allinone, etc.). #}
    <!-- DSFR Stepper -->
    <div class="fr-container fr-mt-4w">
        {% set hasIndex = aSurveyInfo.aQuestionIndex.items is defined and aSurveyInfo.aQuestionIndex.items|length > 0 %}

        {% if hasIndex %}
            {# Mode index activé : libellés d'étapes + "Étape suivante" #}
            {% set totalSteps = aSurveyInfo.aQuestionIndex.items|length %}
            {% set currentStepIndex = 0 %}
            {% set currentStepText = '' %}
            {% set nextStepText = '' %}
            {% for index, item in aSurveyInfo.aQuestionIndex.items %}
                {% if attribute(item.stepStatus, 'index-item-current') is defined and attribute(item.stepStatus, 'index-item-current') == true %}
                    {% set currentStepIndex = index + 1 %}
                    {% set currentStepText = item.text %}
                    {% if aSurveyInfo.aQuestionIndex.items[index + 1] is defined %}
                        {% set nextStepText = aSurveyInfo.aQuestionIndex.items[index + 1].text %}
                    {% endif %}
                {% endif %}
            {% endfor %}
            {% if currentStepIndex == 0 %}
                {% set currentStepIndex = 1 %}
                {% set currentStepText = t.current_step %}
            {% endif %}
        {% else %}
            {# Mode index désactivé : on dérive de `step` (variable globale
               passée par SurveyRuntimeHelper, 1-based, sans soustraction de
               relevant/hidden) pour le numéro d'étape, et de progress.total
               (nb d'étapes visibles, calculé par LS) pour le total. Pas de
               "Étape suivante", mais on récupère le nom du groupe courant
               dans aSurveyInfo.aGroups. #}
            {% set totalSteps = aSurveyInfo.progress.total|default(1) %}
            {% set currentStepIndex = step %}
            {# Sur l'écran "Submit" final, step > totalSteps — on borne pour
               rester cohérent côté ARIA et côté gradient (cf. clamp dans
               stepper-progress.js). #}
            {% if currentStepIndex > totalSteps %}
                {% set currentStepIndex = totalSteps %}
            {% endif %}
            {# En mode "group" / "question", aGroups ne contient que le groupe
               courant (cf. SurveyRuntimeHelper::run() qui filtre sur aStepInfo.gid).
               On prend le premier nom non vide. #}
            {% set currentStepText = '' %}
            {% for _gid, _g in aSurveyInfo.aGroups|default([]) %}
                {% if currentStepText == '' and _g.name is defined and _g.name %}
                    {% set currentStepText = _g.name %}
                {% endif %}
            {% endfor %}
            {% if currentStepText == '' %}
                {% set currentStepText = t.current_step %}
            {% endif %}
            {% set nextStepText = '' %}
        {% endif %}

        <div class="fr-stepper"
             role="progressbar"
             aria-valuenow="{{ currentStepIndex }}"
             aria-valuemin="1"
             aria-valuemax="{{ totalSteps }}"
             aria-label="{{ t.step }} {{ currentStepIndex }} {{ t.of }} {{ totalSteps }}">
            <h2 class="fr-stepper__title">
                {{ currentStepText }}
                <span class="fr-stepper__state">{{ t.step }} {{ currentStepIndex }} {{ t.of }} {{ totalSteps }}</span>
            </h2>
            <div class="fr-stepper__steps"
                 data-fr-current-step="{{ currentStepIndex }}"
                 data-fr-steps="{{ totalSteps }}"
                 aria-hidden="true">
            </div>
            {% if nextStepText %}
                <p class="fr-stepper__details">
                    <span class="fr-text--bold">{{ t.next_step }}</span> {{ nextStepText }}
                </p>
            {% endif %}
        </div>
    </div>
{% endif %}
