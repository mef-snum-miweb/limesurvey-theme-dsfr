{#
/**
 * Date Question - DSFR Theme Override (mode selector)
 *
 * Le serveur LimeSurvey parse la réponse au format d'affichage du sondage
 * (dateformatdetails) : le champ soumis est donc un champ texte au format
 * du sondage (#answer{name}, saisissable sans JS), et l'input natif
 * date/datetime-local n'est que l'UI — synchronisée par
 * src/inputs/date-native.js (conversion générique par tokens).
 *
 * Si le format ne comporte pas jour+mois+année (formats partiels type
 * MM/YYYY), l'input natif ne peut pas le représenter : on retombe sur le
 * champ texte visible, comme le core sans picker.
 *
 * @var $name
 * @var $coreClass
 * @var $dateoutput          Valeur stockée, au format d'affichage
 * @var $mindate / $maxdate  Bornes (peuvent contenir des expressions EM)
 * @var $dateformatdetails   Format d'affichage (PHP-like, pour les libellés)
 * @var $dateformatdetailsjs Format JS (tokens YYYY/MM/DD/HH/mm)
 * @var $hidetip
 */
#}

{% set hasFullDate = 'DD' in dateformatdetailsjs and 'MM' in dateformatdetailsjs and 'YYYY' in dateformatdetailsjs %}
{% set hasTime = 'HH' in dateformatdetailsjs %}
{% set minProcessed = mindate ? processString(mindate) : '' %}
{% set maxProcessed = maxdate ? processString(maxdate) : '' %}

<!-- Date - DSFR -->

<!-- answer -->
<div class="{{ coreClass }}">
    <div class="fr-input-group" id="input-group-{{ name }}">
        <label class="fr-label" for="{{ hasFullDate ? 'answer' ~ name ~ '_native' : 'answer' ~ name }}">
            {{ sprintf(gT('Date format: %s'), dateformatdetails) }}
            {% if hidetip %}
                <span class="fr-hint-text">{{ sprintf(gT('Format: %s'), dateformatdetails) }}</span>
            {% endif %}
        </label>

        {% if hasFullDate %}
            <input
                class="fr-input"
                type="{{ hasTime ? 'datetime-local' : 'date' }}"
                id="answer{{ name }}_native"
                aria-describedby="ls-question-text-{{ name }} input-{{ name }}-messages"
                data-ls-date="{{ name }}"
                data-format="{{ dateformatdetailsjs }}"
                {% if minProcessed %}min="{{ hasTime ? minProcessed|replace({' ': 'T'}) : minProcessed|split(' ')[0] }}"{% endif %}
                {% if maxProcessed %}max="{{ hasTime ? maxProcessed|replace({' ': 'T'}) : maxProcessed|split(' ')[0] }}"{% endif %}
            />
        {% endif %}

        {# Champ RÉPONSE au format du sondage : soumis au serveur, lu par
           l'EM (id answer{name}). Masqué quand l'UI native est disponible,
           saisissable sinon (formats partiels ou no-JS). #}
        {{ C.Html.textField(name, dateoutput, {
            'id': "answer" ~ name,
            'class': 'fr-input date-control date' ~ (hasFullDate ? ' ls-js-hidden' : ''),
            'aria-describedby': "ls-question-text-" ~ name ~ " input-" ~ name ~ "-messages"
        }) }}

        <div class="fr-messages-group" id="input-{{ name }}-messages" aria-live="polite">
        </div>
    </div>
</div>

{# Divs cachées lues par le JS de validation date du core (pas d'espaces
   dans les divs — parsing de chaîne côté core). #}
<div class="d-none" style="display:none">
    <div id="datemin{{ name }}">{{ minProcessed }}</div>
    <div id="datemax{{ name }}">{{ maxProcessed }}</div>
    <div id="dateformat{{ name }}">{{ dateformatdetailsjs }}</div>
</div>
<!-- end of answer -->
