{#
/**
 * Gender question, radio item Html — DSFR
 * Même pattern que yesno/radio : fieldset + legend + un fr-radio-group
 * par item (le ul role=radiogroup sans fieldset n'est pas le composant
 * radio DSFR).
 *
 * @var $name
 * @var $fChecked
 * @var $mChecked
 * @var $naChecked
 * @var $noAnswer
 * @var $value
 */
#}

<!--Gender question, radio display -->

<!-- answer -->
<fieldset class="fr-fieldset ls-answers gender-button" aria-labelledby="ls-question-text-{{ basename }}">
    <legend class="fr-fieldset__legend fr-sr-only">{{ t.choose_option|default('Veuillez choisir l\'une des options suivantes') }}</legend>
    <div class="fr-fieldset__content">
        <!-- Female -->
        <div class="fr-radio-group answer-item radio-item" id="javatbd{{ name }}F">
            <input
                type="radio"
                name="{{ name }}"
                id="answer{{ name }}F"
                value="F"
                {{ fChecked }}
            />
            <label class="fr-label" for="answer{{ name }}F">
                {{ gT('Female') }}
            </label>
        </div>

        <!-- Male -->
        <div class="fr-radio-group answer-item radio-item" id="javatbd{{ name }}M">
            <input
                type="radio"
                name="{{ name }}"
                id="answer{{ name }}M"
                value="M"
                {{ mChecked }}
            />
            <label class="fr-label" for="answer{{ name }}M">
                {{ gT('Male') }}
            </label>
        </div>

        <!-- No answer -->
        {% if noAnswer %}
            <div class="fr-radio-group answer-item radio-item noanswer-item" id="javatbd{{ name }}">
                <input
                    type="radio"
                    name="{{ name }}"
                    id="answer{{ name }}"
                    value=""
                    {{ naChecked }}
                />
                <label class="fr-label" for="answer{{ name }}">
                    {{ gT('No answer') }}
                </label>
            </div>
        {% endif %}
    </div>
</fieldset>
{{ C.Html.hiddenField('java' ~ name, value, ({'id' : 'java' ~ name,'disabled' : 'true'})) }}

<!-- end of answer -->
