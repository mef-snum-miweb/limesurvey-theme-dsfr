{#
/**
 * Array dropdown - DSFR Theme
 * Tableau simple avec liste déroulante
 *
 * @var $sRows      : the rows, generated with the view rows/answer_row.php
 * @var $extraclass
 * @var $answerwidth
 * @var $columnswidth
 * @var $right_exists
 * @var $aRows
 */
#}
<!-- Array Dropdown - DSFR -->
<!-- answer -->
<div class="fr-table fr-table--bordered" role="group" aria-labelledby="ls-question-text-{{ basename }}">
    <div class="fr-table__wrapper">
        <div class="fr-table__container">
            <div class="fr-table__content">
    <table class="{{ coreClass }}">
                    <caption class="fr-sr-only">{{ t.response_matrix|default('Matrice de réponses') }}</caption>
        {# Largeurs configurées en backoffice (answer_width / columns_width). #}
        <colgroup class="col-responses">
            <col class="col-answers" style='width: {{ answerwidth }}%;' />
            <col class="odd" style='width: {{ columnswidth }}%;' />
            {% if right_exists %}
                <col class="col-answersright" style='width: {{ answerwidth }}%;' />
            {% endif %}
        </colgroup>
        <tbody>
            {% for aRow in aRows %}
                {% include 'survey/questions/answer/arrays/array/dropdown/rows/answer_row.twig' with aRow %}
            {% endfor %}
        </tbody>
    </table>
            </div>
        </div>
    </div>
</div>
<!-- end of answer -->
