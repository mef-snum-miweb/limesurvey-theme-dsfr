{#
/**
 * Array, no drop down
 * @var $label
 * @var $ld
 * @var $myfname
 * @var $ld
 * @var $CHECKED
 * @var $checkconditionFunction
 */
#}

<!-- answer_td -->
<td class="answer_cell_{{ ld }}{% if ld=="" %} noanswer-item{% endif %} answer-item radio-item" headers="answertext{{ myfname }} answer{{ basename }}-{{ ld }}">
    <input
        type="radio"
        name="{{ myfname }}"
        value="{{ ld }}"
        id="answer{{ myfname }}-{{ ld }}"
        class="dsfr-radio-table"
        aria-labelledby="answer{{ basename }}-{{ ld }} answertext{{ myfname }}"
        {{ checked }}
    />
    {# Label visible en mode linéarisé mobile. aria-hidden : aria-labelledby
       de l'input porte déjà la relation colonne + ligne pour les SR. #}
    <label for="answer{{ myfname }}-{{ ld }}" class="ls-label-xs-visibility" aria-hidden="true">
        {{ processString(label) }}
    </label>
</td>
<!-- end of answer_td -->
