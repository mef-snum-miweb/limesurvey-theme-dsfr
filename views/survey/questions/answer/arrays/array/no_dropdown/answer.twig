{#
/**
 * Array Flexible (no dropdown) - DSFR Theme
 * Flexible array with radio buttons in cells
 */
#}

<!-- DSFR Array Flexible Table -->
<div class="ls-table-wrapper" role="group" aria-labelledby="ls-question-text-{{ basename }}">
    <div class="fr-table fr-table--bordered" data-fr-js-table="true">
        <table class="{{ coreClass }}" data-fr-js-table-element="true" aria-label="{{ t.response_matrix|default('Matrice de réponses') }}">
        <colgroup class="col-responses">
            <col class="col-answers" style='width: {{ answerwidth }}%;' />
            {% for aColumn in aColumns %}
                <col class="{{ aColumn.class }}" style='width: {{ aColumn.cellwidth }}%'/>
            {% endfor %}
        </colgroup>

        <thead>
            <tr class="ls-heading">
                {{ sHeaders }}
            </tr>
        </thead>

        <tbody>
            {% if anscount == 0 %}
                <tr>
                    <th class="answertext">
                        {{ gT('Error: This question has no answers.') }}
                    </th>
                </tr>
            {% endif %}
            {# Chaque ligne porte son template (answer_row OU repeat_header
               quand l'attribut « Répéter les en-têtes » est actif) : il faut
               inclure aRow.template comme le core — forcer answer_row rendait
               les lignes repeat_header comme des answer_rows corrompues. #}
            {% for aRow in aRows %}
                {% include aRow.template with aRow.content %}
            {% endfor %}
        </tbody>
        </table>
    </div>
</div>
