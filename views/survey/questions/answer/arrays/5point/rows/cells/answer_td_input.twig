{#
/**
 * Array 5 point choice - DSFR Theme Override
 * @var $i
 * @var $myfname
 * @var $CHECKED
 * @var $checkconditionFunction
 * @var $value
 */
#}

<!-- td_input -->
<td class="answer_cell_{{ i }}{% if i=="" %} noanswer-item{% endif %} answer-item radio-item">
    <input
        type="radio"
        name="{{ myfname }}"
        id="answer{{ myfname }}-{{ i }}"
        class="dsfr-radio-table"
        aria-labelledby="answer{{ basename }}-{{ i }} answertext{{ myfname }}"
        value="{{ value }}"
        {{ CHECKED }}
     />
    {# Label visible en mode linéarisé mobile (CSS @media max-width:767px).
       aria-hidden : le lecteur d'écran utilise déjà aria-labelledby de
       l'input, on ne veut pas doubler l'annonce. #}
    <label for="answer{{ myfname }}-{{ i }}" class="ls-label-xs-visibility" aria-hidden="true">
        {{ processString(labelText) }}
    </label>
</td>
<!-- end of td_input -->
