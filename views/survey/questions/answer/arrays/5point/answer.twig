{#
/**
 * Array 5-Point Choice - DSFR Theme
 * Table with DSFR fr-table component
 *
 * Variables:
 * @var $sColumns - Columns HTML
 * @var $sHeaders - Headers HTML
 * @var $sRows - Rows HTML
 * @var $answerwidth - Width percentage
 */
#}

<!-- DSFR Array 5-Point Table -->
<div class="ls-table-wrapper fr-table--responsive" role="group" aria-labelledby="ls-question-text-{{ basename }}">
    <div class="fr-table fr-table--bordered">
    <div class="fr-table__wrapper">
        <div class="fr-table__container">
            <div class="fr-table__content">
                <table class="{{ coreClass }}" aria-labelledby="ls-question-text-{{ basename }}">
                    <caption class="fr-sr-only">{{ t.response_matrix|default('Matrice de réponses') }}</caption>
        <!-- Columns -->
        <colgroup class="col-responses">
            <col class="col-answers" style='width: {{ answerwidth }}%;' />
            {{ sColumns }}
        </colgroup>

        <!-- Table headers -->
        <thead>
            <tr class="ls-heading">
                {{ sHeaders }}
            </tr>
        </thead>

        <!-- Table Body -->
        <tbody>
            {{ sRows }}
        </tbody>
    </table>
            </div>
        </div>
    </div>
    </div>
</div>

<!-- end of answer -->
