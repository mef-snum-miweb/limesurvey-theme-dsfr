{#
/**
 * Array Texts - Grand Total Cell - DSFR Theme
 * Renders the grand total cell
 *
 * @var $empty              Whether cell is empty
 * @var $inputsize          Input size
 * @var $basename           Base name for aria labels
 */
#}

<!-- td_grand_total -->
{% if empty %}
    <td class="grandtotal"></td>
{% else %}
    <td class="grandtotal">
        {# RGAA 10.1 — largeur contrôlée par CSS (unité ch = largeur du 0). #}
        <input
            type="text"
            class="fr-input grandtotal-input"
            readonly="readonly"
            style="width: {{ inputsize ? inputsize : 10 }}ch;"
            aria-label="{{ gT('Grand total') }}"
        />
    </td>
{% endif %}
<!-- end of td_grand_total -->
