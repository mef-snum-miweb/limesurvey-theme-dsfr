{#
/**
 * Array Dual Scale Question - DSFR Theme (No Dropdown)
 * Type: 1 (Array Dual Scale)
 *
 * This template renders two scales for each subquestion
 * Typically used for Importance vs Satisfaction matrices
 *
 * @var $coreClass          Core CSS classes
 * @var $basename           Base name for aria labels
 * @var $answerwidth        Answer column width
 * @var $cellwidth          Cell width for each scale
 * @var $labelans0          First scale answer labels
 * @var $labelcode0         First scale answer codes
 * @var $labelans1          Second scale answer labels
 * @var $labelcode1         Second scale answer codes
 * @var $labelcode0_checked Array of checked states for scale 0
 * @var $labelcode1_checked Array of checked states for scale 1
 * @var $separatorwidth     Separator column width
 * @var $shownoanswer       Whether to show no answer option
 * @var $rightexists        Whether right column exists
 * @var $rightwidth         Right column width
 * @var $leftheader         Left header text (Scale 1 label)
 * @var $rightheader        Right header text (Scale 2 label)
 * @var $aSubQuestions      Array of subquestions with metadata
 */
#}

<!-- Array Dual Scale (Type 1) - DSFR -->
<div role="group" aria-labelledby="ls-question-text-{{ basename }}">
    <div class="fr-table fr-table--bordered">
    <div class="fr-table__wrapper">
        <div class="fr-table__container">
            <div class="fr-table__content">
        <table class="{{ coreClass }}">
            <caption class="fr-sr-only">
                Tableau de {{ aSubQuestions|length }} sous-questions avec deux échelles de réponse
                {%- if leftheader and rightheader -%}
                    {{ ' ' }}: « {{ processString(leftheader) }} » ({{ labelans0|length }} options) et « {{ processString(rightheader) }} » ({{ labelans1|length }} options)
                {%- else -%}
                    {{ ' ' }}de {{ labelans0|length }} et {{ labelans1|length }} options
                {%- endif -%}
                {%- if shownoanswer -%}
                    , avec une option « sans réponse »
                {%- endif -%}
                .
            </caption>
            {# « Sans réponse » : une colonne PAR échelle, accolée aux options
               de son échelle (avant le séparateur pour Scale A) — et non une
               colonne unique en bout de tableau avec les deux radios empilés,
               illisible et impossible à rattacher visuellement à une échelle. #}
            <colgroup class="col-responses">
                <col class="answertext" style="width: {{ answerwidth }}%;" />
                {% for code, label in labelans0 %}
                    <col class="answer-scale0" style="width: {{ cellwidth }}%;" />
                {% endfor %}
                {% if shownoanswer %}
                    <col class="noanswer" style="width: {{ cellwidth }}%;" />
                {% endif %}
                {% if separatorwidth %}
                    <col class="separator" style="width: {{ separatorwidth }}%;" />
                {% endif %}
                {% for code, label in labelans1 %}
                    <col class="answer-scale1" style="width: {{ cellwidth }}%;" />
                {% endfor %}
                {% if shownoanswer and labelcode1 is not empty %}
                    <col class="noanswer" style="width: {{ cellwidth }}%;" />
                {% endif %}
                {% if rightexists %}
                    <col class="answertextright" style="width: {{ rightwidth }}%;" />
                {% endif %}
            </colgroup>

            <thead>
                {% if leftheader or rightheader %}
                    <tr class="ls-heading dualscale-header">
                        <th></th>
                        <th id="scale0-header-{{ basename }}" class="fr-text--bold" colspan="{{ labelans0|length + (shownoanswer ? 1 : 0) }}">{{ processString(leftheader) }}</th>
                        {% if separatorwidth %}<th></th>{% endif %}
                        <th id="scale1-header-{{ basename }}" class="fr-text--bold" colspan="{{ labelans1|length + (shownoanswer and labelcode1 is not empty ? 1 : 0) }}">{{ processString(rightheader) }}</th>
                        {% if rightexists %}<th></th>{% endif %}
                    </tr>
                {% endif %}

                <tr class="ls-heading dualscale-labels">
                    <th></th>
                    {% for code, label in labelans0 %}
                        <th id="answer{{ basename }}-s0-{{ labelcode0[code] }}" class="fr-text--bold answertext">{{ processString(label) }}</th>
                    {% endfor %}
                    {% if shownoanswer %}
                        <th id="noanswer0-header-{{ basename }}" class="fr-text--bold noanswer-text">{{ gT('No answer') }}</th>
                    {% endif %}
                    {% if separatorwidth %}<th></th>{% endif %}
                    {% for code, label in labelans1 %}
                        <th id="answer{{ basename }}-s1-{{ labelcode1[code] }}" class="fr-text--bold answertext">{{ processString(label) }}</th>
                    {% endfor %}
                    {% if shownoanswer and labelcode1 is not empty %}
                        <th id="noanswer1-header-{{ basename }}" class="fr-text--bold noanswer-text">{{ gT('No answer') }}</th>
                    {% endif %}
                    {% if rightexists %}
                        <th></th>
                    {% endif %}
                </tr>
            </thead>

            <tbody>
                {% for i, subquestion in aSubQuestions %}
                    {% if subquestion.repeatheadings %}
                        {{ include('./survey/questions/answer/arrays/dualscale/repeat_header.twig') }}
                    {% endif %}

                    <tr id="javatbd{{ subquestion.myfname }}" class="answers-list dualscale-row {% if i % 2 %}ls-odd{% else %}ls-even{% endif %}{% if subquestion.showmandatoryviolation %} ls-error-mandatory has-error{% endif %}" role="group" aria-labelledby="answertext{{ subquestion.myfname }}">
                        <th scope="row" id="answertext{{ subquestion.myfname }}" class="answertext fr-text--bold{% if answerwidth==0 %} fr-sr-only{% endif %}">
                            {{ processString(subquestion.answertext) }}
                            {# Valeurs pour l'Expression Manager (adressées par id,
                               jamais soumises). Ids en myfid (séparateur « _ ») :
                               em_javascript remplace le « # » des SGQA par « _ »
                               pour construire ses sélecteurs — un id contenant
                               « # » casse relevance/validation/équations. #}
                            {{ C.Html.hiddenField("java"~subquestion.myfid0, subquestion.sessionfname0, ({
                                'id': "java"~subquestion.myfid0,
                                'disabled': true
                            })) }}
                            {% if labelcode1 is not empty %}
                                {{ C.Html.hiddenField("java"~subquestion.myfid1, subquestion.sessionfname1, ({
                                    'id': "java"~subquestion.myfid1,
                                    'disabled': true
                                })) }}
                            {% endif %}
                        </th>

                        {# Entête de groupe Échelle 1 — visible uniquement en
                           mode linéarisé mobile, puisque le <thead> est masqué
                           à cette largeur. Sans ce séparateur, l'utilisateur
                           ne distinguait pas les options de Scale A de celles
                           de Scale B. #}
                        {% if leftheader %}
                            <td class="dualscale-scale-header ls-xs-only" aria-hidden="true">
                                {{ processString(leftheader) }}
                            </td>
                        {% endif %}

                        {# Scale 0 (first scale) #}
                        {% for j, ld in labelcode0 %}
                            <td class="answer_cell_{{ ld }} answer-item radio-item scale0-item" headers="answertext{{ subquestion.myfname }} scale0-header-{{ basename }} answer{{ basename }}-s0-{{ ld }}">
                                <input
                                    type="radio"
                                    name="{{ subquestion.myfname0 }}"
                                    value="{{ ld }}"
                                    id="answer{{ subquestion.myfid0 }}-{{ ld }}"
                                    aria-labelledby="answer{{ basename }}-s0-{{ ld }} answertext{{ subquestion.myfname }}"
                                    {{ labelcode0_checked[subquestion.title][ld]|raw }}
                                />
                                {# Label visible en mode linéarisé mobile. #}
                                <label for="answer{{ subquestion.myfid0 }}-{{ ld }}" class="ls-label-xs-visibility" aria-hidden="true">
                                    {{ processString(labelans0[j]) }}
                                </label>
                            </td>
                        {% endfor %}

                        {# No answer — Échelle 1 : value="" (état « non répondu »).
                           Le core 6.16.16 cache ce radio derrière ls-js-hidden ;
                           on le rend visible (RGAA — l'utilisateur doit pouvoir
                           annuler son choix sur chaque échelle), dans sa propre
                           colonne accolée aux options de l'échelle. #}
                        {% if shownoanswer %}
                            <td class="answer-item radio-item noanswer-item" headers="answertext{{ subquestion.myfname }} {% if leftheader %}scale0-header-{{ basename }} {% endif %}noanswer0-header-{{ basename }}">
                                <div class="dualscale-noanswer">
                                    <input
                                        type="radio"
                                        name="{{ subquestion.myfname0 }}"
                                        value=""
                                        id="answer{{ subquestion.myfid0 }}-"
                                        aria-label="{{ gT("No answer") }}{% if leftheader %} — {{ processString(leftheader)|striptags }}{% endif %}"
                                        {{ subquestion.myfname0_notset|raw }}
                                    />
                                    <label for="answer{{ subquestion.myfid0 }}-" class="ls-label-xs-visibility" aria-hidden="true">
                                        {{ gT("No answer") }}
                                    </label>
                                </div>
                            </td>
                        {% endif %}

                        {# Separator column #}
                        {% if separatorwidth %}
                            <td class="separator">
                                {{ processString(subquestion.answertextcenter) }}
                            </td>
                        {% endif %}

                        {# Entête de groupe Échelle 2 — visible uniquement en
                           mode linéarisé mobile (<thead> masqué à cette largeur). #}
                        {% if rightheader %}
                            <td class="dualscale-scale-header ls-xs-only" aria-hidden="true">
                                {{ processString(rightheader) }}
                            </td>
                        {% endif %}

                        {# Scale 1 (second scale) #}
                        {% for j, ld in labelcode1 %}
                            <td class="answer_cell_{{ ld }} answer-item radio-item scale1-item" headers="answertext{{ subquestion.myfname }} scale1-header-{{ basename }} answer{{ basename }}-s1-{{ ld }}">
                                <input
                                    type="radio"
                                    name="{{ subquestion.myfname1 }}"
                                    value="{{ ld }}"
                                    id="answer{{ subquestion.myfid1 }}-{{ ld }}"
                                    aria-labelledby="answer{{ basename }}-s1-{{ ld }} answertext{{ subquestion.myfname }}"
                                    {{ labelcode1_checked[subquestion.title][ld]|raw }}
                                />
                                {# Label visible en mode linéarisé mobile. #}
                                <label for="answer{{ subquestion.myfid1 }}-{{ ld }}" class="ls-label-xs-visibility" aria-hidden="true">
                                    {{ processString(labelans1[j]) }}
                                </label>
                            </td>
                        {% endfor %}

                        {# No answer — Échelle 2 : même traitement, colonne
                           dédiée après les options de l'échelle 2. #}
                        {% if shownoanswer and labelcode1 is not empty %}
                            <td class="answer-item radio-item noanswer-item" headers="answertext{{ subquestion.myfname }} {% if rightheader %}scale1-header-{{ basename }} {% endif %}noanswer1-header-{{ basename }}">
                                <div class="dualscale-noanswer">
                                    <input
                                        type="radio"
                                        name="{{ subquestion.myfname1 }}"
                                        value=""
                                        id="answer{{ subquestion.myfid1 }}-"
                                        aria-label="{{ gT("No answer") }}{% if rightheader %} — {{ processString(rightheader)|striptags }}{% endif %}"
                                        {{ subquestion.myfname1_notset|raw }}
                                    />
                                    <label for="answer{{ subquestion.myfid1 }}-" class="ls-label-xs-visibility" aria-hidden="true">
                                        {{ gT("No answer") }}
                                    </label>
                                </div>
                            </td>
                        {% endif %}

                        {# Right text column #}
                        {% if rightexists %}
                            <td class="answertextright">
                                {{ processString(subquestion.answertextright) }}
                            </td>
                        {% endif %}
                    </tr>

                {% endfor %}
            </tbody>
        </table>
            </div>
        </div>
    </div>
    </div>
</div>

<!-- end of Array Dual Scale -->
