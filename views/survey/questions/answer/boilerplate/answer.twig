{#
/**
 * Boilerplate Question - DSFR Theme
 * Type: X (Boilerplate/Text Display)
 *
 * Le texte de la question est rendu par le conteneur de question
 * (question_text_content.twig) — ne PAS re-rendre {{ question }} ici
 * (double affichage). Comme le core :
 * - {{ sTimer }} : compte à rebours des attributs time_limit* ;
 * - l'input caché answer{name} : cible du JS timer et de l'EM.
 *
 * @var $name
 * @var $coreClass
 * @var $sTimer
 */
#}

<!-- Boilerplate (Type X) - DSFR -->
{{ sTimer }}

<input class="{{ coreClass }} boilerplate d-none" type="hidden" name="{{ name }}" id="answer{{ name }}" value="" />
<!-- end of Boilerplate -->
