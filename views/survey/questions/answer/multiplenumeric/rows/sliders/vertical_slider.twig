{# Curseur vertical — même contrat que horizontal_slider.twig
   (champ réponse #answer{myfname} vide tant que non touché, range = UI seule,
   logique dans src/inputs/slider-native.js). #}
{% set sliderHasValue = (dispVal is defined and dispVal != '') %}
{% set sliderDefaultApplies = (not sliderHasValue and slider_default_set) %}
{% set sliderAnswerValue = sliderHasValue ? dispVal : (sliderDefaultApplies ? slider_value : '') %}
{% set sliderUiPosition = sliderAnswerValue != ''
    ? sliderAnswerValue|replace({',': '.'})
    : (slider_position != '' ? slider_position : (slider_min + slider_max) / 2) %}
<div class="fr-range-group lsd-range-group--vertical" id="range-group-{{ myfname }}">
    <div class="fr-grid-row fr-grid-row--gutters">
        {% if sliderleft is not empty %}
            <div class="fr-col-12 fr-text--sm fr-mb-1w">
                {{ processString(sliderleft) }}
            </div>
        {% endif %}

        <div class="fr-col-12">
            <div class="fr-range lsd-range--vertical">
                <!-- Affichage de la valeur courante (– si pas encore de réponse) -->
                <span class="fr-range__output" id="output-{{ myfname }}">{{ sliderAnswerValue != '' ? sliderAnswerValue : '–' }}</span>

                <!-- Input range HTML5 natif vertical (UI seule, jamais soumis) -->
                <input
                    id="answer{{ myfname }}slid"
                    type="range"
                    aria-labelledby="label-{{ myfname }}"
                    min="{{ slider_min }}"
                    max="{{ slider_max }}"
                    step="{{ slider_step|default(1) }}"
                    value="{{ sliderUiPosition }}"
                    {% if slider_reversed == 'true' %}dir="rtl"{% endif %}
                    class="slider-item slider-vertical{% if sliderAnswerValue == '' %} slider-untouched{% endif %}"
                    data-slider-orientation="{{ slider_orientation }}"
                    data-ls-slider="{{ myfname }}"
                    data-separator="{{ sSeparator }}"
                    data-prefix="{{ processString(prefix,1) }}"
                    data-suffix="{{ processString(suffix,1) }}"
                    data-reset-position="{{ slider_position != '' ? slider_position : (slider_min + slider_max) / 2 }}"
                    orient="vertical"
                    style="writing-mode: vertical-lr; direction: rtl; height: 200px;"
                />

                {% if slider_showminmax %}
                    <div class="fr-range__minmax">
                        <span class="fr-range__min" aria-hidden="true">
                            {{ slider_reversed == 'false' ? slider_min : slider_max }}
                        </span>
                        <span class="fr-range__max" aria-hidden="true">
                            {{ slider_reversed == 'false' ? slider_max : slider_min }}
                        </span>
                    </div>
                {% endif %}
            </div>
        </div>

        {% if sliderright is not empty %}
            <div class="fr-col-12 fr-text--sm fr-mt-1w">
                {{ processString(sliderright) }}
            </div>
        {% endif %}
    </div>

    {% if slider_reset %}
        <!-- Bouton reset DSFR : revient à l'état « non répondu » -->
        <div class="fr-mt-2w ls-no-js-hidden">
            <button
                id="answer{{ myfname }}_resetslider"
                class="fr-btn fr-btn--secondary fr-btn--sm fr-icon-refresh-line"
                type="button"
                title="{{ gT('Reset') }}"
                aria-label="{{ gT('Reset') }}"
            >
                {{ gT('Reset') }}
            </button>
        </div>
    {% endif %}

    {# Champ RÉPONSE (name={myfname}) : masqué quand JS actif, saisissable
       sans JS (fallback core). Vide = non répondu. #}
    {{ C.Html.textField(myfname, sliderAnswerValue, {
        'class': 'answer-item numeric-item ls-js-hidden' ~ (sliderAnswerValue == '' ? ' slider-untouched' : ''),
        'id': "answer" ~ myfname,
        'aria-labelledby': 'label-' ~ myfname
    }) }}
</div>
