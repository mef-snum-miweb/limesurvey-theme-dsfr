{#
/**
 * Multiple Choice Item Row - DSFR Theme
 * Checkbox with DSFR fr-checkbox-group
 *
 * Variables available:
 * @var $name
 * @var $title
 * @var $question
 * @var $checkedState
 * @var $sCheckconditionFunction
 * @var $myfname
 * @var $sValue
 * @var $kpclass
 * @var $relevanceClass
 */
#}
<!-- answer_row -->
{# `relevanceClass` (ls-irrelevant + ls-disabled/ls-hidden, posée par
   `QuestionBaseRenderer::getCurrentRelevecanceClass()` quand une option
   exclusive est cochée) DOIT rester sur le wrapper `[id^="javatbd"]` —
   c'est le sélecteur que `survey.js` cible pour retirer dynamiquement la
   classe via `relevance:on`. Si on la pose sur le `.fr-checkbox-group`
   interne, le JS ne la voit pas, la classe persiste, le CSS LS core
   `.js .ls-irrelevant { pointer-events: none }` bloque le clic et
   l'utilisateur ne peut plus décocher l'option exclusive. #}
<div class="fr-fieldset__element checkbox-item answer-item {{ relevanceClass }}" id='javatbd{{ myfname }}'>
    <div class="fr-checkbox-group">
        <input
            type="checkbox"
            name="{{ myfname }}"
            id="answer{{ myfname }}"
            {{ checkedState }}
            value="Y"
            aria-label="{{ processString(question) | striptags }}"
            {% if kpclass %}class="{{ kpclass }}"{% endif %}
        />
        <label class="fr-label" for="answer{{ myfname }}">
            {{ processString(question) }}
        </label>
        <input
            type="hidden"
            name="java{{ myfname }}"
            id="java{{ myfname }}"
            value="{{ C.Html.encode( sValue ) }}"
        />
    </div>
</div>
<!-- end of answer_row -->
